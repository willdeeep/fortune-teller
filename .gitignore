# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.so

# uv — keep uv.lock committed for reproducibility
.venv/

# macOS
.DS_Store
**/.DS_Store
._*

# Test artefacts
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Data — never commit scraped or generated data
data/*
!data/models/
!data/parsed/
data/parsed/*
!data/parsed/spreads/
data/parsed/spreads/*
!data/parsed/spreads/celtic-cross.json

# Environment
.env
.envrc

# DuckDB
*.duckdb
*.duckdb.wal

# SQLite
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Editor
.vscode/
.idea/
*.swp
*.swo
*~
.opencode
.claude

# Exception: data/models/ is the install destination for ft-fetch-models
# and should be committed so the app can run offline after the one-time fetch
!data/models/

# Exception: data/parsed/spreads/celtic-cross.json is an authored spread
# (not scraped), committed so it ships with the app
!data/parsed/
!data/parsed/spreads/
!data/parsed/spreads/celtic-cross.json
